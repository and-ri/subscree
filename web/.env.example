# Port the Next.js web server listens on (Next dev defaults to 3000)
PORT=3000

# Backend API base URL. Resolved at RUNTIME by the /api proxy
# (app/api/[...path]/route.js) — not baked into the build — so the same
# image works in any environment. docker-compose sets this to http://server:3001.
API_BASE_URL=http://localhost:3001

# Umami analytics (optional). Both must be set to enable tracking — leave blank
# to disable. Read at RUNTIME by app/layout.js, so the same image works
# anywhere without a rebuild.
#   UMAMI_SCRIPT_URL — full URL to the Umami tracker script
#     (Umami Cloud: https://cloud.umami.is/script.js, or your self-hosted /script.js)
#   UMAMI_WEBSITE_ID — the website UUID from the Umami dashboard
UMAMI_SCRIPT_URL=
UMAMI_WEBSITE_ID=
