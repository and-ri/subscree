# Variables read by docker-compose.yml. Copy to .env next to docker-compose.yml.

# Auth — use a long random string (min 32 chars)
JWT_SECRET=change_me_to_a_long_random_string_min_32_chars

# Public URL where users reach the web app (used in password-reset email links)
APP_URL=http://localhost:3001

# Umami analytics (optional) — set both to enable tracking in the web app.
# UMAMI_SCRIPT_URL: full tracker script URL (e.g. https://cloud.umami.is/script.js)
# UMAMI_WEBSITE_ID: the website UUID from the Umami dashboard
UMAMI_SCRIPT_URL=
UMAMI_WEBSITE_ID=

# Email delivery — configure ONE provider. Resend takes priority if both are set.
# If neither is set, reminder emails are skipped and the scheduler stays off.
EMAIL_FROM=Nook <no-reply@example.com>

# Option A: Resend (https://resend.com) — domain must be verified
RESEND_API_KEY=

# Option B: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
